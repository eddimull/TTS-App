{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TTS Bandmate (web)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--web-port=8715",
        "--web-hostname=0.0.0.0"
      ],
      "toolArgs": [
        "-d", "web-server"
      ],
      "dartDefines": {
        "BASE_URL": "https://localhost:8710"
      }
    },
    {
      "name": "TTS Bandmate (chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "dartDefines": {
        "BASE_URL": "https://localhost:8710"
      }
    }
  ]
}
