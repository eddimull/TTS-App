default_platform(:ios)

platform :ios do
  desc "Submit the already-uploaded build for App Store review (no metadata changes)"
  lane :submit_review do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_PATH"],
    )

    # altool returns as soon as the upload transfers; ASC then spends several
    # minutes "Processing" before the build is submittable. deliver does NOT
    # poll for this, so wait explicitly for the build we just uploaded
    # (identified by build_number:) to finish processing before submitting.
    wait_for_build_processing(
      api_key: api_key,
      app_identifier: "band.tts.mate",
      train_version: options[:version],
      build_version: options[:build_number],
    )

    # Reviewer notes come from the sanitized CHANGELOG section the workflow
    # generated (passed as notes_path:). These go in submission_information's
    # review_notes — NOT what_to_test, which is the TestFlight field.
    submission = { add_id_info_uses_idfa: false }
    notes_path = options[:notes_path]
    if notes_path && File.exist?(notes_path)
      review_notes = File.read(notes_path).strip
      submission[:review_notes] = review_notes unless review_notes.empty?
    end

    deliver(
      api_key: api_key,
      app_identifier: "band.tts.mate",
      app_version: options[:version],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: submission
    )
  end
end
