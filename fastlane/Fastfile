default_platform(:ios)

platform :ios do
  desc "Submit the already-uploaded build for App Store review (no metadata changes)"
  lane :submit_review do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_PATH"],
    )

    # altool returns as soon as the upload transfers; ASC then spends several
    # minutes "Processing" before the build is submittable. deliver does NOT
    # poll for this, so wait explicitly for the build we just uploaded
    # (identified by build_number:) to finish processing before submitting.
    #
    # There is no built-in "wait for processing" action, so poll
    # app_store_build_number until the build we uploaded appears in the edit
    # version (live: false). While the build is still processing the call
    # returns a different/empty number; a *raised* exception instead signals a
    # real problem (bad API key, wrong app id, network). Those fail every call,
    # so bail after a few consecutive failures rather than burning the full
    # timeout — but tolerate the occasional transient blip.
    target_build = options[:build_number].to_s
    deadline = Time.now + (40 * 60) # 40 min; step has a 45 min timeout
    consecutive_failures = 0
    max_consecutive_failures = 3
    loop do
      current =
        begin
          n = app_store_build_number(
            api_key: api_key,
            app_identifier: "band.tts.mate",
            version: options[:version],
            live: false,
          ).to_s
          consecutive_failures = 0
          n
        rescue => e
          consecutive_failures += 1
          if consecutive_failures >= max_consecutive_failures
            UI.user_error!("app_store_build_number failed #{consecutive_failures}x in a row; this looks like a config/auth error, not processing latency: #{e.message}")
          end
          UI.message("Could not read build number yet (attempt #{consecutive_failures}/#{max_consecutive_failures}): #{e.message}; waiting 60s...")
          nil
        end

      break if current == target_build

      UI.message("Build #{target_build} (#{options[:version]}) not processed yet (latest: #{current.to_s.empty? ? 'none' : current}); waiting 60s...") unless current.nil?

      if Time.now > deadline
        UI.user_error!("Timed out waiting for build #{target_build} (#{options[:version]}) to finish processing.")
      end
      sleep(60)
    end

    # App Store requires a "What's New in This Version" (whatsNew) value before a
    # non-first version can be submitted for review — without it the submission
    # fails with "missing required attribute 'whatsNew'". We populate ONLY that
    # one field, from the CHANGELOG: the workflow writes it to
    # fastlane/metadata/en-US/release_notes.txt, and with skip_metadata: false
    # deliver uploads only the metadata files that actually exist on disk. Since
    # release_notes.txt is the only file we write, the rest of the
    # manually-managed App Store listing (name, description, screenshots, etc.)
    # is left untouched.
    #
    # NOTE: App Store *reviewer notes* (app_review_information(notes:)) are a
    # different field and remain unset here. submission_information below only
    # answers the IDFA questionnaire, which is required for review to go through.
    notes_path = "fastlane/metadata/en-US/release_notes.txt"
    unless File.exist?(notes_path) && !File.read(notes_path).strip.empty?
      UI.user_error!("Missing/empty release notes at #{notes_path}. App Store requires a 'What's New' value to submit for review; the workflow's 'Generate release notes' step should have written this file.")
    end

    deliver(
      api_key: api_key,
      app_identifier: "band.tts.mate",
      app_version: options[:version],
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
